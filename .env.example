# AgentForge Red Team Platform — Environment Template
# Copy to `.env` and fill in real values. .env is gitignored; .env.example is committed.
# Required vars are noted; optional vars show their defaults.

# ---------------------------------------------------------------------------
# LLM provider keys
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-api03-..."   # Required: Judge (Sonnet 4.6), Orchestrator (Haiku 4.5), Documentation (Sonnet 4.6) agents
OPENAI_API_KEY="sk-proj-..."           # Required: Red Team agent default (GPT-4o)
OPENROUTER_API_KEY="sk-or-..."         # Optional: fallback for Red Team if GPT-4o refusal rate > 20% on in-scope categories

# ---------------------------------------------------------------------------
# Langfuse (observability — human-readable traces for all agents)
# ---------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY="pk-lf-..."                # Required: Langfuse project public key
LANGFUSE_SECRET_KEY="sk-lf-..."                # Required: Langfuse project secret key
LANGFUSE_HOST="https://us.cloud.langfuse.com"  # Regional: us.cloud / eu.cloud / cloud — match the region your project was created in (auth fails with silent 401 if mismatched). Self-hosted: full base URL.

# ---------------------------------------------------------------------------
# GitLab (vulnerability filing — Documentation Agent opens issues here)
# ---------------------------------------------------------------------------
GITLAB_TOKEN="glpat-..."               # Required: personal/project access token with `api` scope on the AgentForge project
GITLAB_PROJECT_ID="12345"              # Required: numeric ID of the AgentForge GitLab project
GITLAB_URL="https://gitlab.com"        # Default shown; override for self-hosted GitLab

# ---------------------------------------------------------------------------
# Target & platform config
# ---------------------------------------------------------------------------
TARGET_DROPLET_URL="https://143.244.157.90"   # The deployed AgentForge Clinical Co-Pilot target under test
PLATFORM_DB_PATH="var/platform.db"            # SQLite orchestration/state store path; default shown
KILL_SWITCH_ENABLED="false"                   # Boot-time default; runtime control via SQLite-backed flag / CLI

# ---------------------------------------------------------------------------
# Cost caps (optional — defaults exist in code; override here to tighten)
# ---------------------------------------------------------------------------
MAX_SESSION_COST_USD="10.00"           # Orchestrator halts if cumulative session cost exceeds this
MAX_CAMPAIGN_COST_USD="2.00"           # Per-campaign budget cap enforced by the Orchestrator

# ---------------------------------------------------------------------------
# Web UI (operator surface — uvicorn + FastAPI)
# Deployed instance: https://104-248-232-22.sslip.io/ui/  (TLS via Let's Encrypt; /healthz returns 200)
# ---------------------------------------------------------------------------
WEB_UI_HOST="127.0.0.1"                # Bind address. Use 0.0.0.0 to listen on all interfaces.
WEB_UI_PORT="8080"                     # Listen port. nginx proxies to this in prod.
WEB_UI_USER="operator"                 # BasicAuth username (only checked when WEB_UI_PASSWORD is set)
WEB_UI_PASSWORD=""                     # Required IN PRODUCTION. Unset = auth disabled (dev only).
WEB_UI_ENV="dev"                       # Set to "production" on the deployed droplet; systemd unit refuses to boot without WEB_UI_PASSWORD when WEB_UI_ENV=production.
