# AgentForge Red Team Platform — Production environment template.
#
# Copy to /etc/agentforge-redteam/redteam.env on the droplet.
#   - chmod 600
#   - chown agentforge-redteam:agentforge-redteam
#   - referenced by systemd via EnvironmentFile=
#
# REQUIRED values are not optional — the web service will refuse to boot if any
# REQUIRED key is missing or empty.

# ---------------------------------------------------------------------------
# Web UI
# ---------------------------------------------------------------------------

# Bind. The droplet's nginx terminates TLS and proxies to localhost — DO NOT
# expose the uvicorn worker on 0.0.0.0 unless you have a reason.
WEB_UI_HOST=127.0.0.1
WEB_UI_PORT=8080

# REQUIRED. BasicAuth credentials. If WEB_UI_PASSWORD is unset, the app drops
# to dev-mode (no auth). The systemd unit's ExecStartPre asserts this is set.
WEB_UI_USER=operator
WEB_UI_PASSWORD=

# Production mode flag — the unit's ExecStartPre check keys off this.
WEB_UI_ENV=production

# ---------------------------------------------------------------------------
# LLM provider keys (all REQUIRED — agents will not run without them)
# ---------------------------------------------------------------------------

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# Langfuse (observability)
# ---------------------------------------------------------------------------

# Optional. If unset, the platform falls back to NoopLangfuseClient — no traces
# leave the droplet. Set both keys to enable real tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ---------------------------------------------------------------------------
# GitLab (vulnerability filing)
# ---------------------------------------------------------------------------

# Optional. If unset, findings file to the local sink at findings/<slug>-<n>.md.
# Set both to enable real GitLab issue creation by the Documentation agent.
GITLAB_TOKEN=
GITLAB_PROJECT_ID=
GITLAB_URL=https://gitlab.com

# ---------------------------------------------------------------------------
# Target + platform config
# ---------------------------------------------------------------------------

TARGET_DROPLET_URL=https://143.244.157.90
PLATFORM_DB_PATH=/srv/agentforge-redteam/var/platform.db

# ---------------------------------------------------------------------------
# Cost caps (defaults applied if unset — override here to tighten)
# ---------------------------------------------------------------------------

MAX_SESSION_COST_USD=10.00
MAX_CAMPAIGN_COST_USD=2.00
